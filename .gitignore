# Окружение
.venv/
__pycache__/
*.pyc

# Артефакты индекса (пересобираются командой build_index.py)
data/index/*
!data/index/.gitkeep

# Промежуточные артефакты (генерируются скриптами)
data/processed/*
!data/processed/.gitkeep

# Кеш HuggingFace при пересборке данных
.cache/

# IDE
.vscode/
.idea/
.streamlit/
